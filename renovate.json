{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "labels": ["dependencies"],
  "gomod": {
    "schedule": ["* * 7 */3 *"],
    "postUpdateOptions": [
      "gomodUpdateImportPaths",
      "gomodTidy",
      "gomodVendor"
    ],
    "packageRules": [
      {
        "matchManagers": ["gomod"],
        "groupName": "Go modules"
      }
    ]
  },
  "npm": {
    "schedule": ["* * 7 */3 *"],
    "packageRules": [
      {
        "matchManagers": ["npm"],
        "groupName": "NPM packages",
        "enabled": false
      }
    ]
  },
  "dockerfile": {
    "packageRules": [
      {
        "matchManagers": ["dockerfile"],
        "matchPackageNames": "docker.io/library/golang",
        "enabled": false
      }
    ]
  }
}
